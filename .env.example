# Copy this file to .env.local and fill in your values
TELEGRAM_BOT_TOKEN=123456789:AAHeEXAMPLETOKENxxxxxxxxx
TELEGRAM_GROUP_ID=-1001234567890
ADMIN_IDS=123456789,987654321

# Vercel KV (Redis) - Dapatkan dari Dashboard Vercel > Storage > KV
# Catatan: Jika nama database KV kamu "KV_URL", Vercel akan generate variabel dengan prefix KV_URL_
# Isi salah satu format di bawah (yang sesuai dengan env vars di Vercel Dashboard kamu):

# Format tanpa prefix (default):
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxx

# Format dengan prefix KV_URL_ (kalau nama database KV kamu "KV_URL"):
# KV_URL_KV_REST_API_URL=https://xxxx.upstash.io
# KV_URL_KV_REST_API_TOKEN=xxxxxxxxxx
